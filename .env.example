# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Resend (E-Mail-Versand)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# Supabase Service Role Key (for cron jobs — server-side only, never expose to client)
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SerpAPI (Ersatzteil-Suche)
# Get your API key from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your-serpapi-key-here

# App URL (used for generating links in listing descriptions etc.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Contact Form (Ziel-E-Mail für Kontaktanfragen)
CONTACT_EMAIL_TO=kontakt@example.com

# Cron Secret (protects /api/cron/* endpoints from unauthorized access)
# Generate a random string, e.g.: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Beta Mode (set to "true" to give all users premium access and hide upgrade UI)
NEXT_PUBLIC_BETA_MODE=true

# MVP Mode (set to "true" to show Premium as "Coming Soon" with waitlist, hide referral bonus)
NEXT_PUBLIC_MVP_MODE=true

# VAPID Keys (Web Push Notifications)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# Stripe (Freemium / Payment)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Stripe Webhook Secret (for verifying webhook signatures)
# Get from: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create products in Stripe Dashboard → Pricing)
# Monthly: 4,99 €/month, Yearly: 49,99 €/year
STRIPE_PRICE_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_YEARLY=price_your-yearly-price-id
